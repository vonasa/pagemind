# Copy this file to secrets.local.env and fill in your values.
# secrets.local.env is gitignored (matches *.local.*).

# ── Backend axes ────────────────────────────────────────────────────────────────
# local | commercial | anthropic
INDEX_BACKEND=local
QUERY_BACKEND=local

# ── Local OpenAI-compatible model server (Ollama / LM Studio / oMLX) ────────────
LOCAL_BASE_URL=http://localhost:11434
LOCAL_MODEL=gemma3
LOCAL_API_KEY=none

# ── Commercial OpenAI-compatible backend (fill when QUERY_BACKEND=commercial) ───
COMMERCIAL_BASE_URL=https://api.openai.com
COMMERCIAL_MODEL=gpt-4o
COMMERCIAL_API_KEY=

# ── Anthropic backend (fill when QUERY_BACKEND=anthropic) ───────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Embedding server (Infinity, started via docker compose) ─────────────────────
EMBEDDING_URL=http://localhost:7997

# ── Database (started via docker compose) ───────────────────────────────────────
DATABASE_URL=postgresql://pagemind:pagemind@localhost:5432/pagemind

# ── Runtime ─────────────────────────────────────────────────────────────────────
ORCHESTRATOR_MAX_ROUNDS=10
